---
import { User, PenTool, Wrench, ArrowRight } from 'lucide-astro';

const steps = [
  {
    title: "Complimentary Initial Consultation",
    description: "Our Consultation Team will give the best suggestions on design, budget, booth options, size, etc. based on requirements.",
    icon: User,
  },
  {
    title: "FREE 3D Booth Design & Approval",
    description: "Our Design team shares a stunning design that suits your needs and is finalized with your approval.",
    icon: PenTool,
  },
  {
    title: "Booth Setup & Assembly",
    description: "Our World-Class team will guide you or set up the booth for your company based on your requirements.",
    icon: Wrench,
  }
];
---

<section id="process" class="py-10 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Heading Style Provided -->
    <div class="mb-8 md:mb-10 text-center">
      <h2 class="flex items-center justify-center uppercase tracking-[0.2em] text-[26px] md:text-[32px] font-black !text-black">
        <span class="flex-grow border-t-2 border-slate-900 mr-4 max-w-[60px]"></span>
          Our Process
        <span class="flex-grow border-t-2 border-slate-900 ml-4 max-w-[60px]"></span>
      </h2>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 relative">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center group relative">
          
          <!-- Icon Container with Blue Theme -->
          <div class="mb-8 p-6 rounded-full bg-slate-50 border-2 border-secondary/20 transition-all duration-300 group-hover:border-secondary group-hover:bg-white group-hover:shadow-xl group-hover:shadow-secondary/10">
            <step.icon 
              size={48} 
              class="text-secondary" 
              strokeWidth={1.5}
            />
          </div>

          <!-- Text Content -->
          <div class="space-y-4">
            <h3 class="text-[22px] md:text-2xl font-black text-slate-900 leading-tight">
              {step.title}
            </h3>
            <p class="text-slate-700 text-md md:text-xl leading-relaxed font-medium">
              {step.description}
            </p>
          </div>

          <!-- Connector Arrow (Desktop Only) -->
          {index !== steps.length - 1 && (
            <div class="hidden md:block absolute top-12 -right-8 translate-x-1/2 text-slate-500">
              <ArrowRight size={32} />
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex justify-center mt-8">
      <a 
        href="#contact" 
        class="bg-primary text-white text-lg md:text-xl px-14 py-3.5 rounded-2xl font-black transition-all shadow-xl shadow-primary/20 hover:scale-105 active:scale-95"
      >
        Book Consultation
      </a>
    </div>
  </div>
</section>

<style>
  /* Local color overrides based on your requested theme */
  .text-secondary { color: var(--color-secondary, #0074B2); }
  .bg-secondary { background-color: var(--color-secondary, #0074B2); }
  .border-secondary { border-color: var(--color-secondary, #0074B2); }
  .bg-primary { background-color: var(--color-primary, #E76E32); }
  .shadow-primary\/20 { --tw-shadow-color: rgba(231, 110, 50, 0.2); }
</style>