---
import TopBar from './TopBar.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
---
<header class="fixed top-0 left-0 right-0 z-50">
    <TopBar />
    <nav class="bg-white border-b border-gray-100 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="flex items-center">
                        <Image
                            src={logoImg}
                            alt="AVANTE Logo"
                            class="h-12 w-auto object-contain contrast-150 brightness-82"
                        />
                    </a>
                </div>

                <div class="hidden md:flex items-center space-x-8">
                    <a href="#home" class="text-secondary text-lg font-black hover:text-primary transition-colors">Home</a>
                    <a href="#features" class="text-secondary text-lg font-black hover:text-primary transition-colors">Key Benefits</a>
                    <a href="#portfolio" class="text-secondary text-lg font-black hover:text-primary transition-colors">Portfolio</a>
                    <a href="#services" class="text-secondary text-lg font-black hover:text-primary transition-colors">Services</a>
                    
                    <a href="#contact" class="bg-primary text-lg hover:bg-primary/90 text-white px-6 py-2 rounded-2xl font-black transition-all transform hover:scale-105 shadow-lg shadow-primary/20">
                        Get Now
                    </a>
                </div>

                <div class="md:hidden flex items-center">
                    <button type="button" class="text-secondary p-2 transition-transform duration-300" id="mobile-menu-button">
                        <svg id="menu-icon" class="h-8 w-8 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path class="line-1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16" />
                            <path class="line-2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16" />
                            <path class="line-3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div 
            id="mobile-menu" 
            class="md:hidden overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out bg-white border-t border-gray-50"
        >
            <div class="px-6 py-6 space-y-4 shadow-inner">
                <a href="#home" class="mobile-link block text-xl text-secondary font-black translate-x-[-20px] opacity-0 transition-all duration-300 delay-[100ms]">Home</a>
                <a href="#about" class="mobile-link block text-xl text-secondary font-black translate-x-[-20px] opacity-0 transition-all duration-300 delay-[150ms]">Key Benefits</a>
                <a href="#portfolio" class="mobile-link block text-xl text-secondary font-black translate-x-[-20px] opacity-0 transition-all duration-300 delay-[200ms]">Portfolio</a>
                <a href="#products" class="mobile-link block text-xl text-secondary font-black translate-x-[-20px] opacity-0 transition-all duration-300 delay-[250ms]">Services</a>
                <a href="#contact" class="mobile-link block text-xl text-primary font-black translate-x-[-20px] opacity-0 transition-all duration-300 delay-[300ms]">Contact Us</a>
            </div>
        </div>
    </nav>
</header>

<script>
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');
    
    button?.addEventListener('click', () => {
        const isOpen = menu?.style.maxHeight !== '0px' && menu?.style.maxHeight !== '';
        
        if (!isOpen) {
            // Open Menu
            menu.style.maxHeight = '400px'; 
            menu.style.opacity = '1';
            // Trigger link animations
            links.forEach(link => {
                link.classList.remove('translate-x-[-20px]', 'opacity-0');
                link.classList.add('translate-x-0', 'opacity-100');
            });
        } else {
            // Close Menu
            menu.style.maxHeight = '0px';
            menu.style.opacity = '0';
            // Reset link states
            links.forEach(link => {
                link.classList.add('translate-x-[-20px]', 'opacity-0');
                link.classList.remove('translate-x-0', 'opacity-100');
            });
        }
    });

    // Close menu when a link is clicked
    links.forEach(link => {
        link.addEventListener('click', () => {
            menu.style.maxHeight = '0px';
            menu.style.opacity = '0';
        });
    });
</script>

<style>
    /* Prevent layout shift */
    #mobile-menu {
        transition: max-height 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.75s ease-in-out;
    }
</style>