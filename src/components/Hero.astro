---
import { Image } from 'astro:assets';

/* Separate images */
import heroDesktop from '../assets/Hero/heroImg.jpeg';
import heroMobile from '../assets/Hero/heroImg.jpeg';
---

<section
  id="home"
  class="relative min-h-[85vh] lg:min-h-screen flex items-center pt-28 overflow-hidden bg-white lg:bg-[#020617] font-sans"
>
  <!-- Desktop Background -->
  <div class="absolute inset-0 z-0 hidden lg:block" data-reveal data-delay="0">
    <Image
      src={heroDesktop}
      alt="Avante Displays Manufacturing"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-black/65"></div>
  </div>

  <!-- Mobile Background -->
  <div class="absolute inset-0 z-0 lg:hidden mobile-pattern-bg"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-8 w-full">
    <div class="grid lg:grid-cols-2 gap-8 items-center">

      <!-- Left Content -->
      <div class="text-secondary lg:text-white space-y-5 max-w-3xl text-center lg:text-left mx-auto lg:mx-0">

        <!-- Mobile Hero Image -->
        <div class="block lg:hidden mb-8" data-reveal data-delay="1">
          <Image
            src={heroMobile}
            alt="Avante Displays Manufacturing"
            class="w-full h-[230px] rounded-2xl shadow-xl object-cover object-center"
          />
        </div>

        <h1
          class="text-[35px] md:text-[65px] font-[800] leading-[1.1] tracking-tight !text-secondary lg:!text-white"
          data-reveal
          data-delay="1"
        >
          #1 Trade Show Booth Experts in Toronto
        </h1>

        <p
          class="text-[16px] md:text-[20px] text-gray-600 lg:text-gray-200 font-normal max-w-xl leading-relaxed mx-auto lg:mx-0"
          data-reveal
          data-delay="2"
        >
           End-to-End Trade show service from Design to Installation - 
          <span class="text-gray-500 lg:text-gray-300">
            Crafting Trade show Exhibits that stand out and increase visibility
          </span>
        </p>

        <div
          class="flex flex-wrap gap-4 justify-center lg:justify-start"
          data-reveal-left
          data-delay="3"
        >
          <a
            href="#contact"
            class="bg-primary hover:bg-primary/90 text-xl text-white px-10 py-2 md:py-3 rounded-2xl font-black transition-all duration-300 shadow-lg hover:scale-105 active:scale-95"
          >
            Request Quote
          </a>

          <a
            href="#contact"
            class="bg-secondary lg:bg-white hover:opacity-90 lg:hover:bg-gray-100 text-xl text-white lg:text-secondary px-10 py-2 md:py-3 rounded-2xl font-black transition-all duration-300 shadow-md hover:scale-105 active:scale-95"
          >
            Get Free Booth Design
          </a>
        </div>
      </div>

      <!-- Right Form -->
      <div class="lg:ml-auto w-full max-w-lg" data-reveal data-delay="2">
        <div
          class="bg-[#012234]/95 backdrop-blur-sm rounded-[2rem] p-4 md:p-6 shadow-2xl border border-white/10"
        >
          <h3 class="text-center text-[20px] md:text-[24px] font-bold !text-white mb-4 tracking-wide">
            Book Consultation
          </h3>

          <form class="space-y-3">

            <!-- Name -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1">Name</label>
              <input
                type="text"
                placeholder="John Doe"
                class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
              />
            </div>

            <!-- Email + Phone -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-white text-sm font-semibold mb-1">Email</label>
                <input
                  type="email"
                  placeholder="john@example.com"
                  class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                />
              </div>
              <div>
                <label class="block text-white text-sm font-semibold mb-1">Phone</label>
                <input
                  type="tel"
                  placeholder="+1 647-234-2342"
                  class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                />
              </div>
            </div>

            <!-- Company -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1">Company Name</label>
              <input
                type="text"
                placeholder="Doe Pvt. Ltd."
                class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
              />
            </div>

            <!-- Message -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1">How can we help you?</label>
              <textarea
                rows="3"
                placeholder="Requests..."
                class="w-full rounded-xl bg-[#01324d] border border-white/10 px-4 py-3 text-sm text-white placeholder:text-white/40 resize-none focus:outline-none focus:border-white/30"
              ></textarea>
            </div>

            <!-- Button -->
            <button
              type="submit"
              class="w-full h-[46px] rounded-xl bg-[#F97316] hover:bg-[#ea6c10] text-white text-[16px] font-bold transition-all duration-300"
            >
              Submit
            </button>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>


