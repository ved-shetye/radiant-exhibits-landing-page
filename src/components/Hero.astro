---
import { Image } from 'astro:assets';

/* Separate images */
import heroDesktop from '../assets/Hero/heroImg.jpeg';
import heroMobile from '../assets/Hero/heroImg.jpeg';
---

<section
  id="home"
  class="relative min-h-[85vh] lg:min-h-screen flex items-center pt-30 overflow-hidden bg-white lg:bg-[#020617] font-sans"
>
  <!-- Desktop Background -->
  <div class="absolute inset-0 z-0 hidden lg:block" data-reveal data-delay="0">
    <Image
      src={heroDesktop}
      alt="Avante Displays Manufacturing"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-black/65"></div>
  </div>

  <!-- Mobile Background -->
  <div class="absolute inset-0 z-0 lg:hidden mobile-pattern-bg"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-8 w-full">
    <!-- CHANGED TO 12-COLUMN GRID -->
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">

      <!-- Left Content (Takes 7/12 columns now) -->
      <div class="lg:col-span-7 text-secondary lg:text-white space-y-5 max-w-3xl text-center lg:text-left mx-auto lg:mx-0">

        <!-- Mobile Hero Image -->
        <div class="block lg:hidden mb-8" data-reveal data-delay="1">
          <Image
            src={heroMobile}
            alt="Avante Displays Manufacturing"
            class="w-full h-[230px] rounded-2xl shadow-xl object-cover object-center"
          />
        </div>

        <h1
          class="text-[35px] md:text-[65px] font-[800] leading-[1.1] tracking-tight !text-secondary lg:!text-white"
          data-reveal
          data-delay="1"
        >
          #1 Trade Show Booth Experts in Toronto
        </h1>

        <p
          class="text-[15px] md:text-[20px] text-gray-600 lg:text-gray-200 font-normal max-w-xl leading-relaxed mx-auto lg:mx-0"
          data-reveal
          data-delay="2"
        >
            We Help Brands Stand out at Trade Shows with our Custom Exhibit & Rental Booth Solutions - 
          <span class="text-gray-500 lg:text-gray-300">
            Design to Installation | Impactful Concepts
          </span>
        </p>

        <div
          class="flex flex-wrap gap-4 justify-center lg:justify-start"
          data-reveal-left
          data-delay="3"
        >
          <a
            href="#contact"
            class="bg-primary hover:bg-primary/90 text-xl text-white px-10 py-2.5 md:py-3 rounded-2xl font-black transition-all duration-300 shadow-lg hover:scale-105 active:scale-95"
          >
            Request Quote
          </a>

          <a
            href="#contact"
            class="bg-secondary lg:bg-white hover:opacity-90 lg:hover:bg-gray-100 text-xl text-white lg:text-secondary px-10 py-2.5 md:py-3 rounded-2xl font-black transition-all duration-300 shadow-md hover:scale-105 active:scale-95"
          >
            Get Free Booth Design
          </a>
        </div>
      </div>

      <!-- Right Form (Takes 5/12 columns, max-w-md makes it narrower and shifts it further right) -->
      <div class="lg:col-span-5 lg:ml-auto w-full max-w-md" data-reveal data-delay="2">
        <div
          class="bg-[#012234]/95 backdrop-blur-sm rounded-[1.5rem] md:rounded-[2rem] p-6 md:p-7 shadow-2xl border border-white/10"
        >
          <h3 class="text-center text-[20px] md:text-[24px] font-bold !text-white mb-2 tracking-wide">
            Request Quote
          </h3>

          <!-- CHANGED TO space-y-5 FOR A LONGER FEEL -->
          <form id="hero-form" class="space-y-3">

            <!-- Name -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1.5">Name</label>
              <input
                type="text"
                placeholder="John Doe"
                class="w-full h-[40px] md:h-[46px] rounded-2xl bg-[#01324d] border border-white/10 px-4 text-[15px] text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
              />
            </div>

            <!-- Email + Phone -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-white text-sm font-semibold mb-1.5">Email</label>
                <input
                  type="border"
                  placeholder="john@example.com"
                  class="w-full h-[40px] md:h-[46px] rounded-2xl bg-[#01324d] border border-white/10 px-4 text-[15px] text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                />
              </div>
              <div>
                <label class="block text-white text-sm font-semibold mb-1.5">Phone</label>
                <input
                  type="tel"
                  placeholder="+1 647-234-2342"
                  class="w-full h-[40px] md:h-[46px] rounded-2xl bg-[#01324d] border border-white/10 px-4 text-[15px] text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                />
              </div>
            </div>

            <!-- Company -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1.5">Company Name</label>
              <input
                type="text"
                placeholder="Doe Pvt. Ltd."
                class="w-full h-[40px] md:h-[46px] rounded-2xl bg-[#01324d] border border-white/10 px-4 text-[15px] text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
              />
            </div>

            <!-- Message (Increased row height and padding) -->
            <div>
              <label class="block text-white text-sm font-semibold mb-1.5">How can we help you?</label>
              <textarea
                rows="4"
                placeholder="Requests..."
                class="w-full rounded-2xl bg-[#01324d] border border-white/10 px-4 py-3.5 text-[15px] text-white placeholder:text-white/40 resize-none focus:outline-none focus:border-white/30"
              ></textarea>
            </div>

            <!-- Button -->
            <button
              type="submit"
              class="w-full h-[45px] rounded-2xl bg-[#F97316] hover:bg-[#ea6c10] text-white text-[16px] font-bold transition-all duration-300 cursor-pointer"
            >
              Submit
            </button>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
document.getElementById('hero-form').addEventListener('submit', function(e) {
    e.preventDefault();
    window.location.href = '/thankyou';
});
</script>

<style>
  .mobile-pattern-bg {
    background-color: #ffffff;
    background-size: 28px 28px;
    opacity: 1;
  }
</style>