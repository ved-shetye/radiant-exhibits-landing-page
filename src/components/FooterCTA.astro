---
import { Image } from 'astro:assets';
import bgImg from '../assets/Hero/heroImg.jpeg';

const embedUrl = import.meta.env.PUBLIC_PIPEDRIVE_EMBED_URL;
---

<section id="contact" class="relative py-16 overflow-hidden flex items-center">
    <!-- Background -->
    <div class="absolute inset-0">
        <Image src={bgImg} alt="Retail Excellence" class="w-full h-[900px] object-cover" />
        <div class="absolute inset-0 bg-black/60"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-14 items-center">

            <div data-reveal>

                <h2
                    class="text-[36px] md:text-[48px] lg:text-[58px] font-black leading-[0.92] !text-white"
                >
                    Ready to make your

                    <span class="text-[#F97316]">
                        Brand Stand
                    </span>

                    out at the next Trade Show?
                </h2>

                <p
                    class="mt-5 text-[18px] leading-relaxed text-white/90 font-medium max-w-[700px]"
                >
                    Let's build a custom stand strategy together.
                    Free Booth Design in 48 Hours /
                    End-to-End Service /
                    Standout Booths
                </p>

                <div class="flex justify-left mt-7">
                    <a
                        href="https://radiantexhibits.com/contact-us"
                        class="inline-flex items-center justify-center bg-[#F97316] hover:bg-[#ea6c10] text-white text-[20px] font-extrabold px-10 py-3 rounded-2xl transition-all duration-300"
                    >
                        Contact Us
                    </a>
                </div>

            </div>

            <!-- RIGHT FORM -->
            <div
                class="w-full max-w-[760px] lg:ml-auto"
                data-reveal
                data-delay="2"
            >
                <div
                    class="bg-[#012234]/95 backdrop-blur-sm rounded-[2rem] p-4 md:p-6 shadow-[0_20px_80px_rgba(0,0,0,0.45)] border border-white/10"
                >
                    <h3
                        class="text-center text-[20px] md:text-[24px] font-bold !text-white mb-4"
                    >
                        Get Instant Quote
                    </h3>

                    <form class="space-y-3">

                        <!-- Name -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                Name
                            </label>

                            <input
                                type="text"
                                placeholder="John Doe"
                                class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                            />
                        </div>

                        <!-- Email + Phone -->
                        <div class="grid md:grid-cols-2 gap-3">

                            <div>
                                <label class="block text-white text-sm font-semibold mb-1">
                                    Email
                                </label>

                                <input
                                    type="email"
                                    placeholder="john@example.com"
                                    class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                                />
                            </div>

                            <div>
                                <label class="block text-white text-sm font-semibold mb-1">
                                    Phone
                                </label>

                                <input
                                    type="tel"
                                    placeholder="+1 647-234-2342"
                                    class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                                />
                            </div>

                        </div>

                        <!-- Company -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                Company Name
                            </label>

                            <input
                                type="text"
                                placeholder="Doe Pvt. Ltd."
                                class="w-full h-[42px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                            />
                        </div>

                        <!-- Message -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                How can we help you?
                            </label>

                            <textarea
                                rows="3"
                                placeholder="Requests..."
                                class="w-full rounded-xl bg-[#01324d] border border-white/10 px-4 py-3 text-sm text-white placeholder:text-white/40 resize-none focus:outline-none focus:border-white/30"
                            ></textarea>
                        </div>

                        <!-- Button -->
                        <button
                            type="submit"
                            class="w-full h-[46px] rounded-xl bg-[#F97316] hover:bg-[#ea6c10] text-white text-[16px] font-bold transition-all duration-300"
                        >
                            Submit
                        </button>

                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

<script
    is:inline
    src="https://webforms.pipedrive.com/f/loader"
></script>

<script is:inline>
window.addEventListener('message', function(e) {
    if (
        e.data &&
        typeof e.data === 'object' &&
        e.data.type === 'form-submitted'
    ) {
        window.location.href = '/pop-display-ads/thankyou';
    }
});
</script>

<style>
.pipedriveWebForms {
    filter: invert(1) hue-rotate(180deg);
}

.pipedriveWebForms iframe {
    width: 100% !important;
    /*min-height: 560px;*/
    border: none !important;
    background: transparent !important;
    color-scheme: dark;
}
</style>