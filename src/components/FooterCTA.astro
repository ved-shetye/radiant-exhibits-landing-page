---
import { Image } from 'astro:assets';
import bgImg from '../assets/Hero/heroImg.jpeg';
---

<section id="contact" class="relative py-8 overflow-hidden flex items-center">
    <!-- Background -->
    <div class="absolute inset-0">
        <Image src={bgImg} alt="Retail Excellence" class="w-full h-full object-cover object-center absolute inset-0" />
        <div class="absolute inset-0 bg-black/65"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full py-10 lg:py-0">
        <div class="grid lg:grid-cols-[1fr_1.2fr] gap-10 lg:gap-14 items-center">

            <div data-reveal class="text-center lg:text-left">

                <h2
                    class="text-[33px] md:text-[45px] lg:text-[52px] font-black leading-[0.92] !text-white"
                >
                    Ready to make your

                    <span class="text-[#F97316]">
                        Brand Stand
                    </span>

                    out at the next Trade Show?
                </h2>

                <p class="mt-5 text-[17px] md:text-[18px] leading-relaxed text-white font-medium">
                    Let's build a custom stand strategy together.
                </p>

                <ul class="mt-4 space-y-3 inline-block text-left">
                    <li class="flex items-center gap-3 text-white/90 font-semibold text-[14px] md:text-[16px]">
                        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-[#F97316] shrink-0">
                            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                        </span>
                        Free Booth Design in 72 Hours
                    </li>
                    <li class="flex items-center gap-3 text-white font-semibold text-[14px] md:text-[16px]">
                        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-[#F97316] shrink-0">
                            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                        </span>
                        End-to-End Service
                    </li>
                    <li class="flex items-center gap-3 text-white font-semibold text-[14px] md:text-[16px]">
                        <span class="flex items-center justify-center w-6 h-6 rounded-full bg-[#F97316] shrink-0">
                            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                        </span>
                        Captivating Booths
                    </li>
                </ul>

                <div class="flex justify-center lg:justify-start mt-7">
                    <a
                        href="#footer-cta-form"
                        id="contact-us-btn"
                        class="inline-flex items-center justify-center bg-[#F97316] hover:bg-[#ea6c10] text-white text-[20px] font-extrabold px-22 py-3.5 rounded-2xl transition-all duration-300 cursor-pointer"
                    >
                        Contact Us
                    </a>
                </div>

            </div>

            <!-- RIGHT FORM -->
            <div
                class="w-full max-w-[820px] lg:ml-auto"
                data-reveal
                data-delay="2"
            >
                <div
                    class="bg-[#012234]/95 backdrop-blur-sm rounded-[2rem] px-6 md:px-7 pt-4 pb-8 shadow-[0_20px_80px_rgba(0,0,0,0.45)] border border-white/10"
                >
                    <h3
                        class="text-center text-[20px] md:text-[24px] font-bold !text-white mb-4"
                    >
                        Request Quote
                    </h3>

                    <form id="footer-cta-form" class="space-y-5">

                        <!-- Name -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                Name
                            </label>

                            <input
                                id="cta-name-input"
                                type="text"
                                placeholder="John Doe"
                                class="w-full h-[40px] md:h-[46px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                            />
                        </div>

                        <!-- Email + Phone -->
                        <div class="grid md:grid-cols-2 gap-3">

                            <div>
                                <label class="block text-white text-sm font-semibold mb-1">
                                    Email
                                </label>

                                <input
                                    type="email"
                                    placeholder="john@example.com"
                                    class="w-full h-[40px] md:h-[46px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                                />
                            </div>

                            <div>
                                <label class="block text-white text-sm font-semibold mb-1">
                                    Phone
                                </label>

                                <input
                                    type="tel"
                                    placeholder="+1 647-234-2342"
                                    class="w-full h-[40px] md:h-[46px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                                />
                            </div>

                        </div>

                        <!-- Company -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                Company Name
                            </label>

                            <input
                                type="text"
                                placeholder="Doe Pvt. Ltd."
                                class="w-full h-[40px] md:h-[46px] rounded-xl bg-[#01324d] border border-white/10 px-4 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30"
                            />
                        </div>

                        <!-- Message -->
                        <div>
                            <label class="block text-white text-sm font-semibold mb-1">
                                How can we help you?
                            </label>

                            <textarea
                                rows="3"
                                placeholder="Requests..."
                                class="w-full rounded-2xl bg-[#01324d] border border-white/10 px-4 py-5 text-sm text-white placeholder:text-white/40 resize-none focus:outline-none focus:border-white/30"
                            ></textarea>
                        </div>

                        <!-- Button -->
                        <button
                            type="submit"
                            class="w-full h-[40px] md:h-[49px] rounded-2xl bg-[#F97316] hover:bg-[#ea6c10] text-white text-[16px] font-bold transition-all duration-300 cursor-pointer"
                        >
                            Submit
                        </button>

                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

<script is:inline>
document.getElementById('contact-us-btn')?.addEventListener('click', function(e) {
    e.preventDefault();
    const nameInput = document.getElementById('cta-name-input');
    if (nameInput) {
        nameInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => {
            nameInput.focus();
        }, 400);
    }
});

document.getElementById('footer-cta-form').addEventListener('submit', function(e) {
    e.preventDefault();
    window.location.href = '/thankyou';
});
</script>