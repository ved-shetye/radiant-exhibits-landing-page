---
import { Image } from 'astro:assets';
import faqImg from '../assets/faq.png';
import { ChevronDown } from 'lucide-astro';

const faqs = [
    {
        q: "What types of trade show booths does Radiant Exhibits offer?",
        a: "We offer a full range of booth solutions including custom island exhibits, inline booths, modular displays, portable pop-up systems, and fabric tension displays. Every design is tailored to your brand, budget, and show requirements."
    },
    {
        q: "Does Radiant Exhibits handle installation and dismantling?",
        a: "Yes — we provide complete end-to-end service. Our team handles delivery, professional installation at the venue, and full dismantling after the show. You show up, focus on your business, and we handle the rest.",
        isProcess: true
    },
    {
        q: "How does the design process work?",
        a: "We start with a discovery call to understand your goals, brand, and booth space. From there our team moves through concept development, 3D rendering for your approval, and then full production and finishing.",
        isSteps: true
    },
    {
        q: "How far in advance should I book for a trade show?",
        a: "We recommend reaching out at least 6–8 weeks before your show date for custom builds. For modular or portable systems we can often turn things around faster. Contact us early to lock in your timeline."
    },
    {
        q: "Do you serve trade shows across all of Canada?",
        a: "Yes. Radiant Exhibits services trade shows and events across Canada, including Toronto, Vancouver, Calgary, Montreal, and beyond. We coordinate logistics and installation wherever your show takes place."
    }
];
---

<section id="faq" class="py-10 bg-[#D9F2F9] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        
        <!-- Black Line-Accented Heading -->
        <div class="mb-6 md:mb-8">
            <h2 class="flex items-center text-center justify-center uppercase tracking-[0.2em] text-[26px] md:text-[32px] font-[900] md:font-[800] !text-black">
                <span class="flex-grow border-t-2 border-black mr-4 max-w-[60px]"></span>
                Frequently Asked Questions
                <span class="flex-grow border-t-2 border-black ml-4 max-w-[60px]"></span>
            </h2>
        </div>

        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-4 lg:gap-16 items-center pb-1 md:pb-6">

            <!-- Image on the Left -->
            <div class="w-full lg:col-span-5" data-reveal>
                <div class="overflow-hidden flex justify-center">
                    <Image
                        src={faqImg}
                        alt="Retail Display Solutions"
                        class="w-full max-w-full lg:max-w-none h-auto lg:h-[360px] object-contain transition-transform duration-700 hover:scale-105"
                    />
                </div>
            </div>

            <!-- Content on the Right -->
            <div class="w-full lg:col-span-7 space-y-3 mt-2 lg:mt-0" data-reveal data-delay="1">
                {faqs.map((faq) => (
                    <div class="faq-item group">
                        <!-- Decreased Font Size: text-sm -->
                        <button class="faq-btn w-full text-left px-5 py-4 bg-white rounded-2xl flex justify-between items-center gap-4 transition-all duration-300 shadow-sm hover:shadow-md">
                            <span class="text-sm font-bold text-slate-800 leading-snug">{faq.q}</span>
                            <div class="bg-slate-50 p-1 rounded-full border border-slate-100 shrink-0">
                                <ChevronDown class="faq-icon w-4 h-4 text-secondary transition-transform duration-300" />
                            </div>
                        </button>

                        <div class="faq-body overflow-hidden transition-all duration-300" style="max-height:0">
                            <!-- Decreased Font Size: text-sm -->
                            <div class="px-6 py-5 text-slate-600 text-sm leading-relaxed bg-white/80 backdrop-blur-sm rounded-b-2xl border-x border-b border-white/50">
                                <p class="mb-3 font-medium text-secondary">{faq.a}</p>

                                {faq.isProcess && (
                                    <div class="mt-3 grid grid-cols-2 gap-2">
                                        {[
                                            { phase: "Phase 1", label: "Discovery Call" },
                                            { phase: "Phase 2", label: "Delivery & Logistics" },
                                            { phase: "Phase 3", label: "Installation" },
                                            { phase: "Phase 4", label: "Dismantling" },
                                        ].map(p => (
                                            <div class="bg-white/60 p-2 rounded-xl border border-white text-center">
                                                <p class="text-[9px] uppercase font-bold text-secondary/60">{p.phase}</p>
                                                <p class="font-bold text-[11px] text-secondary">{p.label}</p>
                                            </div>
                                        ))}
                                    </div>
                                )}

                                {faq.isSteps && (
                                    <div class="mt-3 grid grid-cols-2 gap-2">
                                        {[
                                            { phase: "Step 1", label: "Discovery Call" },
                                            { phase: "Step 2", label: "Concept & 3D Render" },
                                            { phase: "Step 3", label: "Production" },
                                            { phase: "Step 4", label: "Delivery & Install" },
                                        ].map(p => (
                                            <div class="bg-white/60 p-2 rounded-xl border border-white text-center">
                                                <p class="text-[9px] uppercase font-bold text-secondary/60">{p.phase}</p>
                                                <p class="font-bold text-[11px] text-secondary">{p.label}</p>
                                            </div>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>

        </div>
    </div>
</section>

<script>
    function initFaq() {
        const items = document.querySelectorAll('.faq-item');

        items.forEach((item) => {
            const btn  = item.querySelector('.faq-btn') as HTMLElement;
            const body = item.querySelector('.faq-body') as HTMLElement;
            const icon = item.querySelector('.faq-icon') as HTMLElement;

            btn?.addEventListener('click', () => {
                const isOpen = !!body.style.maxHeight && body.style.maxHeight !== '0px';

                items.forEach((other) => {
                    const b  = other.querySelector('.faq-body') as HTMLElement;
                    const ic = other.querySelector('.faq-icon') as HTMLElement;
                    const bt = other.querySelector('.faq-btn');
                    if (b)  b.style.maxHeight = '0px';
                    if (ic) ic.style.transform = 'rotate(0deg)';
                    if (bt) bt.classList.remove('rounded-b-none', 'ring-2', 'ring-secondary/20');
                });

                if (!isOpen) {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    icon.style.transform = 'rotate(180deg)';
                    btn.classList.add('rounded-b-none', 'ring-2', 'ring-secondary/20');
                }
            });
        });
    }

    initFaq();
    document.addEventListener('astro:after-swap', initFaq);
</script>

<style>
    .faq-item .faq-body {
        transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .faq-btn.rounded-b-none {
        border-bottom-left-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }
</style>