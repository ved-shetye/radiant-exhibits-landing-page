---
import { Image } from 'astro:assets';
import faqImg from '../assets/faq.png';
import { ChevronDown } from 'lucide-astro';

const brands = [
    ["Dish Network", "Ethan Allan", "iPlay"],
    ["Kong", "Rockwell", "Watkins Home Products"],
    ["Sylvania", "Nature's Way", "American Gifts"],
    ["Stander", "Abbott Collection", "Wander & Ivy"],
    ["Riversol", "StanPro", "Brondell"],
    ["National Geographic", "Robeez", "LineX"]
];

const faqs = [
    {
        q: "What Brand Names are using Avante POP Displays?",
        a: "Here are just a few of the companies that Avante has created permanent POP Displays for:",
        isBrands: true
    },
    {
        q: "Do POP retail store displays really work?",
        a: "YES! Point-of-purchase advertising is essential. Studies reveal that 70% of brand purchase decisions are made in-store, and custom displays deliver a 2:1 sales advantage.",
        isTable: true
    },
    {
        q: "How does the design process work?",
        a: "We start by determining your product volume and budget. Our team then moves through conceptualization to 3D rendering and final production.",
        isProcess: true
    },
    {
        q: "What are the advantages of buying 'factory direct'?",
        a: "At Avante, we design, print, and build in-house. This eliminates the middle-man, keeping costs down and ensuring design-to-build consistency."
    }
];
---

<section id="faq" class="py-10 bg-[#D9F2F9] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        
        <!-- Black Line-Accented Heading -->
        <div class="mb-2">
            <h2 class="flex items-center text-center justify-center uppercase tracking-[0.2em] text-[20px] md:text-[32px] font-[900] md:font-[800] text-secondary">
                <span class="flex-grow border-t-2 border-secondary mr-4 max-w-[60px]"></span>
                Frequently Asked Questions
                <span class="flex-grow border-t-2 border-secondary ml-4 max-w-[60px]"></span>
            </h2>
        </div>

        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-8 lg:gap-16 items-center pb-6">

            <!-- Image on the Left -->
            <div class="w-full lg:col-span-5" data-reveal>
                <div class="overflow-hidden">
                    <Image
                        src={faqImg}
                        alt="Retail Display Solutions"
                        class="w-full h-[360px] object-cover transition-transform duration-700 hover:scale-105"
                    />
                </div>
            </div>

            <!-- Content on the Right -->
            <div class="w-full lg:col-span-7 space-y-3" data-reveal data-delay="1">
                {faqs.map((faq) => (
                    <div class="faq-item group">
                        <!-- Decreased Font Size: text-sm -->
                        <button class="faq-btn w-full text-left px-5 py-4 bg-white rounded-2xl flex justify-between items-center gap-4 transition-all duration-300 shadow-sm hover:shadow-md">
                            <span class="text-sm font-bold text-slate-800 leading-snug">{faq.q}</span>
                            <div class="bg-slate-50 p-1 rounded-full border border-slate-100 shrink-0">
                                <ChevronDown class="faq-icon w-4 h-4 text-secondary transition-transform duration-300" />
                            </div>
                        </button>

                        <div class="faq-body overflow-hidden transition-all duration-300" style="max-height:0">
                            <!-- Decreased Font Size: text-sm -->
                            <div class="px-6 py-5 text-slate-600 text-sm leading-relaxed bg-white/80 backdrop-blur-sm rounded-b-2xl border-x border-b border-white/50">
                                <p class="mb-3 font-medium text-secondary">{faq.a}</p>

                                {faq.isBrands && (
                                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mt-3">
                                        {brands.flat().map(brand => (
                                            <div class="flex items-center gap-2 text-[11px] bg-white/50 p-1.5 rounded-lg border border-white/40">
                                                <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
                                                {brand}
                                            </div>
                                        ))}
                                    </div>
                                )}

                                {faq.isProcess && (
                                    <div class="mt-3 grid grid-cols-2 gap-2">
                                        {[
                                            { phase: "Phase 1", label: "Initial Concept" },
                                            { phase: "Phase 2", label: "CAD Drawing" },
                                            { phase: "Phase 3", label: "3D Rendering" },
                                            { phase: "Phase 4", label: "Production" },
                                        ].map(p => (
                                            <div class="bg-white/60 p-2 rounded-xl border border-white text-center">
                                                <p class="text-[9px] uppercase font-bold text-secondary/60">{p.phase}</p>
                                                <p class="font-bold text-[11px] text-secondary">{p.label}</p>
                                            </div>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>

        </div>
    </div>
</section>

<script>
    function initFaq() {
        const items = document.querySelectorAll('.faq-item');

        items.forEach((item) => {
            const btn  = item.querySelector('.faq-btn') as HTMLElement;
            const body = item.querySelector('.faq-body') as HTMLElement;
            const icon = item.querySelector('.faq-icon') as HTMLElement;

            btn?.addEventListener('click', () => {
                const isOpen = !!body.style.maxHeight && body.style.maxHeight !== '0px';

                items.forEach((other) => {
                    const b  = other.querySelector('.faq-body') as HTMLElement;
                    const ic = other.querySelector('.faq-icon') as HTMLElement;
                    const bt = other.querySelector('.faq-btn');
                    if (b)  b.style.maxHeight = '0px';
                    if (ic) ic.style.transform = 'rotate(0deg)';
                    if (bt) bt.classList.remove('rounded-b-none', 'ring-2', 'ring-secondary/20');
                });

                if (!isOpen) {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    icon.style.transform = 'rotate(180deg)';
                    btn.classList.add('rounded-b-none', 'ring-2', 'ring-secondary/20');
                }
            });
        });
    }

    initFaq();
    document.addEventListener('astro:after-swap', initFaq);
</script>

<style>
    .faq-item .faq-body {
        transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .faq-btn.rounded-b-none {
        border-bottom-left-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }
</style>