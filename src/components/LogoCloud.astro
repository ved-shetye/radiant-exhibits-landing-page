---
import { Image } from 'astro:assets';

/*
  Automatically import every image inside:
  src/assets/CompanyLogos/

  Supported formats below:
  png, jpg, jpeg, webp, svg, avif
  (add/remove formats if you want)
*/
const logoModules = import.meta.glob(
  '/src/assets/CompanyLogos/*.{png,jpg,jpeg,webp,svg,avif,PNG,JPG,JPEG,WEBP,SVG,AVIF}',
  { eager: true }
);

const logos = Object.entries(logoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const fileName = path.split('/').pop()?.replace(/\.[^/.]+$/, '') || 'Client Logo';

    return {
      src: (mod as any).default,
      alt: fileName.replace(/[-_]+/g, ' ')
    };
  });
---

<section id="clients" class="py-8 bg-white overflow-hidden select-none">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-2 text-center">
    <h2 class="flex items-center justify-center uppercase tracking-[0.2em] text-[26px] md:text-[32px] font-black !text-black">
      Our Clients
    </h2>
  </div>

  <div class="w-full overflow-hidden ticker-wrapper cursor-grab active:cursor-grabbing">
    <div class="flex gap-8 ticker-track items-center py-4">
      {[...logos, ...logos].map((logo, index) => (
        <div
          class="bg-white px-8 py-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center min-w-[220px] h-28 flex-shrink-0 pointer-events-none"
          key={`logo-${index}`}
        >
          <Image
            src={logo.src}
            alt={logo.alt}
            class="max-h-18 w-auto object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const wrapper = document.querySelector('.ticker-wrapper');
    const track = document.querySelector('.ticker-track');

    if (!wrapper || !track) return;

    let currentX = 0;
    const speed = 1; // auto scroll speed
    let isDragging = false;
    let startX = 0;
    let startY = 0;
    let dragStartX = 0;
    let mode = null;

    function updateTicker() {
      if (!isDragging) {
        currentX -= speed;
      }

      const halfWidth = track.scrollWidth / 2;

      if (Math.abs(currentX) >= halfWidth) {
        currentX += halfWidth;
      } else if (currentX > 0) {
        currentX -= halfWidth;
      }

      track.style.transform = `translate3d(${currentX}px, 0, 0)`;
      requestAnimationFrame(updateTicker);
    }

    requestAnimationFrame(updateTicker);

    const getPageX = (e) => {
      if (e.touches && e.touches[0]) return e.touches[0].pageX;
      return e.pageX;
    };

    const getPageY = (e) => {
      if (e.touches && e.touches[0]) return e.touches[0].pageY;
      return e.pageY;
    };

    const startDrag = (e) => {
      isDragging = true;
      mode = null;
      startX = getPageX(e);
      startY = getPageY(e);
      dragStartX = startX - currentX;
    };

    const moveDrag = (e) => {
      if (!isDragging) return;

      const x = getPageX(e);
      const y = getPageY(e);
      const dx = x - startX;
      const dy = y - startY;

      if (!mode) {
        if (Math.abs(dx) < 5 && Math.abs(dy) < 5) return;
        mode = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
      }

      if (mode === 'x') {
        if (e.cancelable) {
          e.preventDefault();
        }
        currentX = x - dragStartX;
      } else if (mode === 'y') {
        isDragging = false;
      }
    };

    const stopDrag = () => {
      isDragging = false;
      mode = null;
    };

    // Mouse
    wrapper.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', moveDrag);
    window.addEventListener('mouseup', stopDrag);
    wrapper.addEventListener('mouseleave', stopDrag);

    // Touch
    wrapper.addEventListener('touchstart', startDrag, { passive: true });
    window.addEventListener('touchmove', moveDrag, { passive: false });
    window.addEventListener('touchend', stopDrag);
  })();
</script>

<style>
  .ticker-wrapper {
    position: relative;
    width: 100%;
    touch-action: pan-y; /* keeps vertical page scrolling working on mobile */
  }

  .ticker-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }
</style>