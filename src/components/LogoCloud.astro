---
import { Image } from 'astro:assets';

import logo1 from '../assets/CompanyLogos/3m.png';
import logo2 from '../assets/CompanyLogos/bausch+lomb.png';
import logo3 from '../assets/CompanyLogos/bayer.png';
import logo4 from '../assets/CompanyLogos/calidon.png';
import logo5 from '../assets/CompanyLogos/cathelle.png';
import logo6 from '../assets/CompanyLogos/coast-music.png';
import logo7 from '../assets/CompanyLogos/coldwell-banker.png';
import logo8 from '../assets/CompanyLogos/dakine.png';
import logo9 from '../assets/CompanyLogos/fresenius-kabi.png';
import logo10 from '../assets/CompanyLogos/rbc.png';
import logo11 from '../assets/CompanyLogos/shoppers-drug-mart.png';

const logos = [
  { src: logo1, alt: 'Client Logo 1' },
  { src: logo2, alt: 'Client Logo 2' },
  { src: logo3, alt: 'Client Logo 3' },
  { src: logo4, alt: 'Client Logo 4' },
  { src: logo5, alt: 'Client Logo 5' },
  { src: logo6, alt: 'Client Logo 6' },
  { src: logo7, alt: 'Client Logo 7' },
  { src: logo8, alt: 'Client Logo 8' },
  { src: logo9, alt: 'Client Logo 9' },
  { src: logo10, alt: 'Client Logo 10' },
  { src: logo11, alt: 'Client Logo 11' },
];
---

<section id="clients" class="py-10 bg-white overflow-hidden select-none">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-6 text-center">
    <h2 class="flex items-center justify-center uppercase text-[26px] md:text-[32px] font-black !text-black">
        Our Clients
    </h2>
  </div>

  <!-- Using native horizontal scroll container (scrollbars hidden via CSS) -->
  <div class="flex overflow-x-auto py-1 cursor-grab active:cursor-grabbing ticker-container scroll-smooth-none" data-reveal data-delay="2">
    <div class="flex gap-8 logo-ticker items-center">
      {/* We render two sets to handle seamless looping via scroll positioning */}
      {[...logos, ...logos].map((logo) => (
        <div
          class="bg-white px-8 py-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center min-w-[220px] h-28 hover:shadow-md hover:border-secondary/20 transition-all duration-300 flex-shrink-0 pointer-events-none"
        >
          <Image
            src={logo.src}
            alt={logo.alt}
            class="max-h-18 w-auto object-contain transition-all duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  const container = document.querySelector('.ticker-container');
  
  if (container) {
    let isDown = false;
    let startX;
    let scrollLeft;
    let speed = 1; // Pixels per frame auto-scroll speed
    let animationFrameId;

    // 1. Auto Scroll Loop Function
    function step() {
      if (!isDown) {
        container.scrollLeft += speed;
        
        // Loop back seamlessly when reaching halfway through the duplicate contents
        const maxScroll = container.scrollWidth / 2;
        if (container.scrollLeft >= maxScroll) {
          container.scrollLeft -= maxScroll;
        } else if (container.scrollLeft <= 0) {
          container.scrollLeft += maxScroll;
        }
      }
      animationFrameId = requestAnimationFrame(step);
    }

    // Initialize Auto-scroll loop
    animationFrameId = requestAnimationFrame(step);

    // 2. Drag Interaction Listeners
    container.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
    });

    container.addEventListener('mouseleave', () => {
      isDown = false;
    });

    container.addEventListener('mouseup', () => {
      isDown = false;
    });

    container.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX) * 1.5; // Drag sensitivity modifier
      container.scrollLeft = scrollLeft - walk;

      // Wrap around bounds check during manual drag
      const maxScroll = container.scrollWidth / 2;
      if (container.scrollLeft >= maxScroll) {
        container.scrollLeft -= maxScroll;
        startX = x - (scrollLeft - container.scrollLeft); // Reset baseline anchor points
      } else if (container.scrollLeft <= 0) {
        container.scrollLeft += maxScroll;
        startX = x - (scrollLeft - container.scrollLeft);
      }
    });
  }
</script>

<style>
  /* Hide native scrollbars cleanly across browsers */
  .ticker-container {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .ticker-container::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  .logo-ticker {
    white-space: nowrap;
  }
</style>