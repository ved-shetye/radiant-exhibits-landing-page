---
/* Astro Frontmatter */
---
<div class="pre-header">
    <div class="pre-header-content">
        <p class="promo-text">Free Booth Design in 72 Hours </p>
        <a href="#contact" class="cta-button">Claim now!</a>
    </div>
</div>

<style>
    .pre-header {
        width: 100%; /* Changed from 1280px to 100% for responsiveness */
        height: 42px;
        background: #0074B2;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .pre-header-content {
        display: flex;
        align-items: center;
        gap: 15px; /* Adjusts the space between text and button */
    }

    .promo-text {
        font-family: 'Lato', sans-serif;
        font-style: normal;
        font-weight: 800;
        font-size: 17px;
        line-height: 19px;
        text-align: center;
        color: #FFFFFF;
        margin: 0;
    }
    .cta-button {
        background: #FFFFFF;
        border-radius: 15px;
        width: 116px;
        height: 28px;
        display: flex;
        justify-content: center;
        align-items: center;
        
        font-family: 'Lato', sans-serif;
        font-style: normal;
        font-weight: 900;
        font-size: 17px;
        line-height: 19px;
        text-align: center;
        text-decoration: none;
        color: #0074B2;
        
        transition: opacity 0.2s ease;
    }

    .cta-button:hover {
        opacity: 0.9;
        scale: 1.05
    }
</style>