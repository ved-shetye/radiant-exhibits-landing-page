---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
import { MapPin, Mail, Phone, ChevronRight } from 'lucide-astro';

const contactInfo = {
  email: "Sales@radiantexhibits.com",
  phone: "416-412-0500",
  address: "150 Milner Ave Unit #19, Toronto, ON M1S 3R3",
  tagline: "#1 Custom Trade Show Booth Exhibits in Canada",
  termsUrl: "https://radiantexhibits.com/terms"
};
---

<footer class="bg-dark text-white pt-12 pb-6 font-sans border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-8">

      <div class="space-y-6">
        <div class="flex items-center">
          <a href="/" class="transition-opacity hover:opacity-80">
            <Image
              src={logoImg}
              alt="Radiant Exhibits Logo"
              class="h-18 w-auto object-contain brightness-0 invert"
            />
          </a>
        </div>
        <div class="space-y-6">
          <p class="text-accent text-sm leading-relaxed max-w-[300px] font-medium">
            {contactInfo.tagline}
          </p>
        </div>
      </div>

      <!-- Quick Links Section -->
      <div>
        <h4 class="text-primary font-black text-xl mb-8 uppercase tracking-wider">Quick Links</h4>
        <ul class="space-y-4">
          {[
            { label: 'Home',      href: '#home'      },
            { label: 'Key Benefits',     href: '#features'  },
            { label: 'Portfolio', href: '#portfolio' },
            { label: 'Services',  href: '#services'  },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/80 hover:text-primary transition-all duration-300 flex items-center gap-2 group text-base">
                <ChevronRight size={14} class="text-primary group-hover:translate-x-1 transition-transform" />
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Us Section -->
      <div>
        <h4 class="text-primary font-black text-xl mb-8 uppercase tracking-wider">Contact Us</h4>
        <div class="space-y-6">
          <!-- Direct Address Placement -->
          <div class="flex items-start gap-4 group">
            <div class="bg-white/5 p-2.5 rounded-lg group-hover:bg-primary/10 transition-colors shrink-0">
              <MapPin size={20} class="text-primary" />
            </div>
            <div class="space-y-1">
              <p class="text-xs uppercase tracking-widest text-white/40 font-bold">Office Address</p>
              <p class="text-white font-medium leading-relaxed">
                150 Milner Ave Unit #19,<br />
                Toronto, ON M1S 3R3
              </p>
            </div>
          </div>

          <div class="pt-2 space-y-4">
             <a href={`mailto:${contactInfo.email}`} class="flex items-center gap-4 text-white hover:text-primary transition-colors group">
              <div class="bg-white/5 p-2.5 rounded-lg group-hover:bg-primary/10 transition-colors shrink-0">
                <Mail size={18} />
              </div>
              <span class="font-bold text-sm md:text-base">{contactInfo.email}</span>
            </a>
            
            <a href={`tel:${contactInfo.phone.replace(/-/g, '')}`} class="flex items-center gap-4 text-white hover:text-primary transition-colors group">
               <div class="bg-white/5 p-2.5 rounded-lg group-hover:bg-primary/10 transition-colors shrink-0">
                <Phone size={18} />
              </div>
              <span class="font-bold text-sm md:text-base">{contactInfo.phone}</span>
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/30 uppercase tracking-widest font-bold">
      <p>© 2026 Radiant Exhibits. All Rights Reserved.</p>
      
      <div class="flex items-center gap-6">
        <a href={contactInfo.termsUrl} target="_blank" class="hover:text-white transition-colors">Terms & Conditions</a>
        <span class="text-white/10">|</span>
        <a href={contactInfo.termsUrl} class="hover:text-white transition-colors">Privacy Policy</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .bg-dark { background-color: #012345; }
  .text-primary { color: #E76E32; }
  .text-accent { color: #C0EAF4; }
</style>