---
import { Star, ChevronLeft, ChevronRight } from 'lucide-astro';
import { Image } from 'astro:assets';

// Asset Imports
import client1 from '../assets/Testimonials/client6.png';
import client2 from '../assets/Testimonials/client2.png';
import client3 from '../assets/Testimonials/client3.png';
import client4 from '../assets/Testimonials/client4.png';
import client5 from '../assets/Testimonials/CompanyTestimony1.jpg';
import client6 from '../assets/Testimonials/CompanyTestimony2.png';
import client7 from '../assets/Testimonials/CompanyTestimony3.png';
import client8 from '../assets/Testimonials/CompanyTestimony4.png';
import verifiedLogo from '../assets/Testimonials/VerifiedLogo.png';

const testimonials = [
  {
    type: "google",
    title: "Extremely Fair Price",
    quote: "Absolutely fantastic team. Went above and beyond for our booth. Had insanely fast response times, got us last minute things going into the weekend, and came in at an extremely fair price. I would 100% reccomend Radiant for your booth needs!",
    author: "Camille Moore",
    designation: "Marketing Manager",
    image: client1,
    rating: 5,
    fontSize: "text-[15px]" 
  },
  {
    type: "google",
    title: "Team was Incredibly Responsive",
    quote: "We recently worked with Radiant Exhibits to create a custom 20ft lightbox for the Together We Care conference in Toronto – all while coordinating from another country. The team was incredibly responsive and delivered exactly what we needed. Truly excellent service.",
    author: "Danté McSharry",
    designation: "Event Coordinator",
    image: client2,
    rating: 5
  },
  {
    type: "google",
    title: "Worked with them for 5+ Years",
    quote: "We have worked with the team at Radiant for the past 5+ years. The service provided on a scale of 1 to 10 is 20! This rating covers service, professionalism, quality, the entire process! They go above and beyond to ensure everything is taken care of.",
    author: "Rose Noble",
    designation: "Local Guide",
    image: client3,
    rating: 5
  },
  {
    type: "google",
    title: "Setup was Done Quickly",
    quote: "Thank you Radiant for your help with our exhibit booth! Julian and his team were excellent in communicating and made sure we had what we needed to make our booth look great and run smoothly. Setup was done quickly and on time. Would definitely recommend!",
    author: "Yvette Madrid",
    designation: "Brand Lead",
    image: client4,
    rating: 5
  },
  {
    type: "company",
    title: "Good as it is",
    quote: "Radiant team …. our new solar booth has been spectacular and the versatility of multiple configurations allows us to choose a booth space that gives us the best position in the highest traffic areas. ",
    author: "Tashina Alam",
    designation: "Fresenius Kabi",
    image: client5,
    rating: 5,
    logoWidth: "max-w-[180px]",
    logoHeight: "max-h-[30px]"
  },
  {
    type: "company",
    title: "Made us Stand Out",
    quote: "Radiant Exhibits offered us an amazing rental booth that made us a standout at the show, all for a fraction of the cost of purchasing. We prefer renting as it gives us design flexibility and we can expense 100% of it.",
    author: "Silvanna Soleanu",
    designation: "Basilur Tea",
    image: client6,
    rating: 5,
    logoWidth: "max-w-[120px]",
    logoHeight: "max-h-[80px]"
  }, 
  {
    type: "company",
    title: "Pulled Together on Short Notice",
    quote: "….. the show went well, better than expected and we made some good connections. Thank you guys for pulling this together for us in such short notice, the booth looked great! It wa great working with Dan and we will keep you guys in the loop for other shows.",
    author: "Raj Gill",
    designation: "Mosino",
    image: client8,
    rating: 5,
    logoWidth: "max-w-[50px]",
    logoHeight: "max-h-[23px]"
  }
];
---

<section id="testimony" class="py-9 bg-slate-50 relative overflow-hidden">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="mb-6 md:mb-8">
            <h2 class="flex items-center justify-center uppercase tracking-[0.2em] text-[26px] md:text-[30px] font-black !text-slate-900 text-center">
                <span class="flex-grow border-t-2 border-slate-900 mr-4 max-w-[60px]"></span>
                Testimonials
                <span class="flex-grow border-t-2 border-slate-900 ml-4 max-w-[60px]"></span>
            </h2>
            <p class="text-center text-secondary font-bold text-lg mt-3">Hear from Our Clients in Canada</p>
        </div>

        <div class="relative group px-4 lg:px-12">
            <!-- Navigation Arrows -->
            <button class="swiper-prev absolute left-1 md:left-2 lg:left-4 top-1/2 -translate-x-2/3 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-full bg-white border border-slate-200 text-slate-700 shadow-md hover:bg-slate-50 hover:text-secondary focus:outline-none transition-all duration-300 cursor-pointer">
                <ChevronLeft class="w-5 h-5 md:w-6 md:h-6" />
            </button>
            <button class="swiper-next absolute right-1 md:right-2 lg:right-4 top-1/2 translate-x-2/3 -translate-y-1/2 z-20 flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-full bg-white border border-slate-200 text-slate-700 shadow-md hover:bg-slate-50 hover:text-secondary focus:outline-none transition-all duration-300 cursor-pointer">
                <ChevronRight class="w-5 h-5 md:w-6 md:h-6" />
            </button>

            <!-- Swiper Container -->
            <div class="swiper testimonialSwiper !pb-12 md:!pb-16">
                <div class="swiper-wrapper">
                    {testimonials.map((item) => (
                        <div class="swiper-slide">
                            <div class="bg-white border border-slate-200 p-6 md:p-8 rounded-[32px] w-full h-auto flex flex-col hover:shadow-xl transition-all duration-300 shadow-md cursor-pointer select-none">
                                
                                <!-- Card Header Layout -->
                                <div class="flex justify-between items-start mb-6">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex text-yellow-500 gap-0.5">
                                            {[...Array(item.rating)].map(() => (
                                                <Star class="w-4 h-4 fill-current" />
                                            ))}
                                        </div>
                                        <span class="text-[10px] text-slate-500 font-semibold tracking-wider uppercase">Verified Review</span>
                                    </div>
                                    
                                    <!-- Dynamic Badging Realignment -->
                                    <div>
                                        {item.type === "google" ? (
                                            <div class="flex items-center gap-1 opacity-90">
                                                <img 
                                                    src="https://www.gstatic.com/images/branding/googlelogo/svg/googlelogo_clr_74x24px.svg" 
                                                    alt="Google Logo" 
                                                    class="w-14 h-auto" 
                                                />
                                                <span class="text-[13px] font-bold text-slate-500">Reviews</span>
                                            </div>
                                        ) : (
                                            <div class="flex items-center opacity-95">
                                                <Image 
                                                    src={verifiedLogo} 
                                                    alt="Verified Business Review Seal" 
                                                    class="h-9 md:h-10 w-auto object-contain"
                                                />
                                            </div>
                                        )}
                                    </div>
                                </div>

                                <!-- Quote Body Section -->
                                <h3 class="text-[23px] font-black mb-3 text-secondary text-center">"{item.title}"</h3>
                                <p class={`text-slate-700 leading-relaxed italic font-medium flex-grow mb-8 text-center px-2 ${item.fontSize || 'text-[15.5px]'}`}>
                                    “{item.quote}”
                                </p>

                                <!-- Card Footer Layout -->
                                <div class="flex items-center gap-4 border-t border-slate-100 pt-5 mt-auto">
                                    {item.type === 'company' ? (
                                        item.author.includes("Silvanna") ? (
                                            /* Clean layout adjustment for Basilur Tea's square proportions */
                                            <div class="w-14 h-14 flex items-center justify-center bg-white rounded-xl p-1 shrink-0">
                                                <Image 
                                                    src={item.image} 
                                                    alt={item.author} 
                                                    class="max-w-full max-h-full object-contain" 
                                                />
                                            </div>
                                        ) : (
                                            /* Standard rectangular wide frame for landscape corporate logos */
                                            <div class="w-30 h-12 flex items-center justify-center border border-transparent rounded-none p-1 shrink-0">
                                                <Image 
                                                    src={item.image} 
                                                    alt={item.author} 
                                                    class="max-w-full max-h-full object-contain" 
                                                />
                                            </div>
                                        )
                                    ) : (
                                        /* Standard Round User Avatars for Google Reviews */
                                        <Image 
                                            src={item.image} 
                                            alt={item.author} 
                                            class="w-11 h-11 rounded-full border border-slate-100 object-cover shrink-0" 
                                        />
                                    )}
                                    <div class="overflow-hidden text-left">
                                        <p class="font-bold text-slate-900 text-sm tracking-wide truncate">{item.author}</p>
                                        <p class="text-xs text-secondary font-medium truncate">{item.designation}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="swiper-pagination !bottom-0"></div>
            </div>
        </div>
    </div>
</section>

<style>
    .swiper-wrapper {
        display: flex;
        align-items: flex-start;
    }

    :global(.testimonialSwiper .swiper-slide) {
        height: auto !important;
    }

    :global(.testimonialSwiper .swiper-slide),
    :global(.testimonialSwiper .swiper-slide *) {
        cursor: pointer !important;
    }

    :global(.swiper-pagination-bullet) {
        background: #b4c6d4 !important;
        opacity: 0.5;
        width: 8px;
        height: 8px;
    }
    :global(.swiper-pagination-bullet-active) {
        background: #0074B2 !important;
        opacity: 1;
        width: 24px;
        border-radius: 4px;
        transition: all 0.3s;
    }
    
    /* Variable helper classes */
    .bg-dark { background-color: #012345; }
    .bg-secondary { background-color: #0074B2; }
    .text-secondary { color: #0074B2; }
    .bg-primary { background-color: #E76E32; }
    .text-primary { color: #E76E32; }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/navigation';
    import 'swiper/css/pagination';

    function initSwiper() {
        new Swiper('.testimonialSwiper', {
            modules: [Navigation, Pagination, Autoplay],
            slidesPerView: 1,
            spaceBetween: 24,
            loop: true,
            autoHeight: true,
            autoplay: {
                delay: 6000, 
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
            },
            navigation: {
                nextEl: '.swiper-next',
                prevEl: '.swiper-prev',
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
            slidesPerGroup: 1,
            breakpoints: {
                768: {
                    slidesPerView: 2,
                },
                1024: {
                    slidesPerView: 3,
                    spaceBetween: 28,
                },
            },
        });
    }

    initSwiper();
    document.addEventListener('astro:after-swap', initSwiper);
</script>