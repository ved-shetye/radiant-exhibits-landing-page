---
import { Star, ChevronLeft, ChevronRight } from 'lucide-astro';

const testimonials = [
  {
    title: "300% Sales Growth!",
    quote: "Our sales increased by over 300% in the 6 months after the new displays were placed in the stores. Three years and 4 ingenious POP displays later, we are known for the most appealing and functional displays.",
    author: "Steve Rezek",
    designation: "Marketing Director, BevCo",
    image: "https://randomuser.me/api/portraits/men/32.jpg",
    rating: 5
  },
  {
    title: "Highly Recommend Avante",
    quote: "Our retailers love our custom displays! Since placing these displays we have noticed a significant increase in sales. Avante team have been great throughout the whole process from design to delivery.",
    author: "Yasaman",
    designation: "Founder, Green Retail",
    image: "https://randomuser.me/api/portraits/women/44.jpg",
    rating: 5
  },
  {
    title: "Game Changer for us",
    quote: "The interactive kiosks changed how customers interact with our brand. The build quality is exceptional and the setup was seamless. Truly a top-tier partner for retail growth.",
    author: "Marcus Chen",
    designation: "Operations Head, TechWorld",
    image: "https://randomuser.me/api/portraits/men/46.jpg",
    rating: 5
  },
  {
    title: "Superior Quality",
    quote: "We've tried several display manufacturers, but Avante's attention to detail and custom wood finishes are unmatched. They understand the luxury market perfectly.",
    author: "Sarah Jenkins",
    designation: "Brand Manager, Luxe & Co",
    image: "https://randomuser.me/api/portraits/women/12.jpg",
    rating: 5
  },
  {
    title: "Incredible Support",
    quote: "The team went above and beyond to meet our tight deadline for the expo. The displays arrived perfectly packed and were the highlight of our booth. We really loved way things were handled.",
    author: "David Vales",
    designation: "Project Manager, Global Trade",
    image: "https://randomuser.me/api/portraits/men/52.jpg",
    rating: 5
  }
];
---

<section id="testimony" class="py-9 bg-slate-50 relative overflow-hidden">
    <!-- Subtle Background Accents to match the light theme -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="mb-8">
            <h2 class="flex items-center justify-center uppercase tracking-[0.2em] text-[20px] md:text-[30px] font-black !text-slate-900 text-center">
                <span class="flex-grow border-t-2 border-slate-900 mr-4 max-w-[60px]"></span>
                Testimonials
                <span class="flex-grow border-t-2 border-slate-900 ml-4 max-w-[60px]"></span>
            </h2>
            <p class="text-center text-secondary font-bold text-lg mt-1">Hear from our Global Clients</p>
        </div>

        <!-- Outer Group Container Wrapper: Widened padding to fit outer arrows perfectly -->
        <div class="relative group px-4 lg:px-12">
            
            <!-- Navigation Buttons: Left and Right styling mapped directly to image_a8077b.png edges -->
            <button class="swiper-prev absolute left-0 top-1/2 -translate-y-1/2 z-20 bg-white border border-slate-200 hover:bg-secondary/10 hover:text-secondary text-slate-400 p-3 rounded-full transition-all shadow-md hidden lg:flex items-center justify-center">
                <ChevronLeft size={20} />
            </button>
            <button class="swiper-next absolute right-0 top-1/2 -translate-y-1/2 z-20 bg-white border border-slate-200 hover:bg-secondary/10 hover:text-secondary text-slate-400 p-3 rounded-full transition-all shadow-md hidden lg:flex items-center justify-center">
                <ChevronRight size={20} />
            </button>

            <!-- Swiper Container -->
            <div class="swiper testimonialSwiper !pb-12">
                <div class="swiper-wrapper">
                    {testimonials.map((item) => (
                        <div class="swiper-slide !h-auto flex">
                            <div class="bg-white border border-slate-100 p-8 rounded-[32px] w-full flex flex-col hover:shadow-xl transition-all duration-300 shadow-sm">
                                
                                <!-- Card Header Layout -->
                                <div class="flex justify-between items-start mb-6">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex text-yellow-500 gap-0.5">
                                            {[...Array(item.rating)].map(() => (
                                                <Star class="w-4 h-4 fill-current" />
                                            ))}
                                        </div>
                                        <span class="text-[10px] text-slate-400 font-semibold tracking-wider uppercase">Verified Review</span>
                                    </div>
                                    
                                    <div class="flex items-center gap-1 opacity-80">
                                      <img 
                                        src="https://www.gstatic.com/images/branding/googlelogo/svg/googlelogo_clr_74x24px.svg" 
                                        alt="Google Logo" 
                                        class="w-14 h-auto" 
                                      />
                                      <span class="text-[13px] font-bold text-slate-400">Reviews</span>
                                    </div>
                                </div>

                                <!-- Quote Body Section: Matches the exact centering layout -->
                                <h3 class="text-lg font-black mb-3 text-secondary text-center">"{item.title}"</h3>
                                <p class="text-slate-500 leading-relaxed italic text-[14.5px] font-medium flex-grow mb-8 text-center px-2">
                                    “{item.quote}”
                                </p>

                                <!-- Card Footer: Kept perfectly left-aligned for author data layouts -->
                                <div class="flex items-center gap-3 border-t border-slate-100 pt-5 mt-auto">
                                    <img src={item.image} alt={item.author} class="w-11 h-11 rounded-full border border-slate-100 object-cover shrink-0" />
                                    <div class="overflow-hidden text-left">
                                        <p class="font-bold text-slate-900 text-sm tracking-wide truncate">{item.author}</p>
                                        <p class="text-xs text-secondary font-medium truncate">{item.designation}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="swiper-pagination !bottom-0"></div>
            </div>
        </div>
    </div>
</section>

<style>
    .swiper-wrapper {
        display: flex;
    }

    :global(.swiper-pagination-bullet) {
        background: #b4c6d4 !important;
        opacity: 0.5;
        width: 8px;
        height: 8px;
    }
    :global(.swiper-pagination-bullet-active) {
        background: #0074B2 !important;
        opacity: 1;
        width: 24px;
        border-radius: 4px;
        transition: all 0.3s;
    }
    
    /* Variable helper classes */
    .bg-dark { background-color: #012345; }
    .bg-secondary { background-color: #0074B2; }
    .text-secondary { color: #0074B2; }
    .bg-primary { background-color: #E76E32; }
    .text-primary { color: #E76E32; }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/navigation';
    import 'swiper/css/pagination';

    function initSwiper() {
        new Swiper('.testimonialSwiper', {
            modules: [Navigation, Pagination, Autoplay],
            slidesPerView: 1,
            spaceBetween: 24,
            loop: true,
            autoplay: {
                delay: 6000, 
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
            },
            navigation: {
                nextEl: '.swiper-next',
                prevEl: '.swiper-prev',
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
            slidesPerGroup: 1,
            breakpoints: {
                768: {
                    slidesPerView: 2,
                },
                1024: {
                    slidesPerView: 3,
                    spaceBetween: 28,
                },
            },
        });
    }

    initSwiper();
    document.addEventListener('astro:after-swap', initSwiper);
</script>