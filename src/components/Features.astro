---
import { Clock, PenTool, Wrench, ShieldCheck, Zap, HeartHandshake, MapPin, BadgeCheck } from 'lucide-astro';

const features = [
    { 
        title: "72 Hours Booth Design",
        description: "Tailor-made 3D Mockup designs that align with your exhibition goals.",                                                                    
        Icon: Clock   
    },
    { 
        title: "Premium Clientele",           
        description: "Trusted by top brands like 3M, Bayer, RBC, and Harley Davidson to deliver high-impact exhibition presence.",                                                       
        Icon: BadgeCheck   
    },
    { 
        title: "True End-to-End Management",              
        description: "Design, Assembly, Installation, Logistics, Warehousing, and Concierge services handled entirely in-house.",                                
        Icon: Wrench   
    },
    { 
        title: "Booth Lifecycle Planning",     
        description: "Strategic program management and planning aligned with your long-term multi-show exhibit goals.",                                           
        Icon: Zap  
    },
    { 
        title: "Experienced Marketing",               
        description: "With 30+ years of expertise, our design team crafts booths engineered to capture attention and drive ROI.",                                                                     
        Icon: PenTool  
    },
    { 
        title: "Cost Efficient",                
        description: "Proprietary internal logistics and inventory management strategies provide a significant competitive cost advantage.",                          
        Icon: HeartHandshake  
    },
    { 
        title: "24/7 Project Management",                
        description: "Dedicated account managers reachable 24/7 to ensure seamless execution from concept to teardown.",                          
        Icon: ShieldCheck  
    },
    { 
        title: "Canadian Company",                
        description: "Headquartered in Canada, providing local market expertise and streamlined logistics for domestic exhibitions.",                          
        Icon: MapPin  
    },
];
---

<section id="features" class="pt-11 pb-12 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header Section -->
        <div class="text-center mb-12" data-reveal data-delay="1">
            <h4 class="flex items-center justify-center uppercase tracking-[0.2em] text-[13px] md:text-[18px] font-black !text-black mb-1">
                <span class="flex-grow border-t-2 border-slate-900 mr-4 max-w-[60px]"></span>
                Key Benefits - Radiant Exhibits
                <span class="flex-grow border-t-2 border-slate-900 ml-4 max-w-[60px]"></span>
            </h4>
            <h2 class="text-[28px] md:text-[44px] font-[900] text-secondary leading-tight">
                Custom Trade Show Exhibit Experts
            </h2>
        </div>

        <!-- Features Grid -->
        <div class="grid md:grid-cols-2 gap-x-16 gap-y-8 px-4 md:px-8">
            {features.map((f, i) => (
                <div class="flex items-start space-x-6" data-reveal data-delay={i + 2}>
                    <div class="flex-shrink-0 w-16 h-16 border-2 border-secondary/20 rounded-2xl flex items-center justify-center hover:bg-secondary hover:text-white transition-all duration-300 group">
                        <f.Icon class="w-8 h-8 text-secondary group-hover:text-white transition-colors duration-300" />
                    </div>
                    <div class="space-y-2">
                        <h3 class="text-[18px] md:text-[22px] font-black text-secondary leading-snug">{f.title}</h3>
                        <p class="text-slate-700 font-medium text-[12px] md:text-[15px] leading-relaxed">{f.description}</p>
                    </div>
                </div>
            ))}
        </div>

        <!-- CTA Button -->
        <div class="flex justify-center mt-8" data-reveal-left data-delay="9">
            <a href="#contact" class="bg-primary hover:bg-primary/90 text-white px-12 py-3 rounded-2xl text-lg md:text-xl font-bold transition-all shadow-xl shadow-primary/25 hover:scale-105 active:scale-95">
                Book Consultation
            </a>
        </div>
    </div>
</section>

<style is:global>
    /* Standardized Stagger Delays */
    [data-delay="1"] { transition-delay: 0.04s; }
    [data-delay="2"] { transition-delay: 0.08s; }
    [data-delay="3"] { transition-delay: 0.12s; }
    [data-delay="4"] { transition-delay: 0.16s; }
    [data-delay="5"] { transition-delay: 0.2s; }
    [data-delay="6"] { transition-delay: 0.24s; }
    [data-delay="7"] { transition-delay: 0.28s; }
    [data-delay="8"] { transition-delay: 0.32s; }
    [data-delay="9"] { transition-delay: 0.36s; }
    [data-delay="10"] { transition-delay: 0.4s; }
</style>